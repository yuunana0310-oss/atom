{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MedicalVisualExample",
  "type": "object",
  "required": ["id", "title", "theme", "category", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "theme": { "type": "string" },
    "category": { "type": "string" },
    "target_audience": { "type": "string" },
    "purpose": { "type": "string" },
    "medium": { "type": "string" },
    "size": { "type": "string" },
    "slide_count": { "type": "integer", "minimum": 1 },
    "style": { "type": "string" },
    "main_visual": { "type": "string" },
    "information_density": { "type": "string", "enum": ["low", "medium", "high", "very_high"] },
    "gpt_used": { "type": "string" },
    "prompt": { "type": "string" },
    "output_image_url": { "type": "string" },
    "success_points": { "type": "string" },
    "failure_points": { "type": "string" },
    "revision_notes": { "type": "string" },
    "threads_post_text": { "type": "string" },
    "note_link": { "type": "string" },
    "posted_status": { "type": "string", "enum": ["not_posted", "draft", "posted", "reused"] },
    "performance_notes": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

